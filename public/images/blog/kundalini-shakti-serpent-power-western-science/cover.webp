<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <radialGradient id="bg4" cx="50%" cy="40%" r="70%">
      <stop offset="0%" stop-color="#1a0a2e"/>
      <stop offset="100%" stop-color="#0A0A0F"/>
    </radialGradient>
    <linearGradient id="serpent-g" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FFD700"/>
      <stop offset="30%" stop-color="#C9A84C"/>
      <stop offset="60%" stop-color="#9B7BC9"/>
      <stop offset="100%" stop-color="#4ECDC4"/>
    </linearGradient>
    <linearGradient id="chakra-g" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#C9A84C"/>
      <stop offset="25%" stop-color="#9B7BC9"/>
      <stop offset="50%" stop-color="#4ECDC4"/>
      <stop offset="75%" stop-color="#7B5EA7"/>
      <stop offset="100%" stop-color="#C9A84C"/>
    </linearGradient>
    <filter id="serpent-glow">
      <feGaussianBlur stdDeviation="4" result="glow"/>
      <feMerge><feMergeNode in="glow"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <rect width="1200" height="630" fill="url(#bg4)"/>
  <!-- Central spinal column (subtle) -->
  <line x1="600" y1="60" x2="600" y2="570" stroke="#2a1a4a" stroke-width="3"/>
  <!-- 7 chakra LOTUS circles -->
  <g transform="translate(600,120)">
    <!-- Muladhara (Root) - Red/Orange -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#FF6B35" stroke-width="1.5"/>
      <circle r="10" fill="#FF6B35" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,195)">
    <!-- Svadhisthana (Sacral) - Orange -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#FF8C42" stroke-width="1.5"/>
      <circle r="10" fill="#FF8C42" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,270)">
    <!-- Manipura (Solar) - Yellow -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#C9A84C" stroke-width="1.5"/>
      <circle r="10" fill="#C9A84C" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,345)">
    <!-- Anahata (Heart) - Green -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#4ECDC4" stroke-width="1.5"/>
      <circle r="10" fill="#4ECDC4" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,420)">
    <!-- Vishuddha (Throat) - Blue -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#5B9BD5" stroke-width="1.5"/>
      <circle r="10" fill="#5B9BD5" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,495)">
    <!-- Ajna (Third Eye) - Indigo -->
    <g opacity="0.8">
      <circle r="18" fill="none" stroke="#7B5EA7" stroke-width="1.5"/>
      <circle r="10" fill="#7B5EA7" opacity="0.4"/>
    </g>
  </g>
  <g transform="translate(600,555)">
    <!-- Sahasrara (Crown) - Violet/Gold -->
    <g filter="url(#serpent-glow)">
      <circle r="22" fill="none" stroke="#C9A84C" stroke-width="1.5"/>
      <circle r="12" fill="#C9A84C" opacity="0.5"/>
    </g>
  </g>
  <!-- Serpent coiled around spine -->
  <g fill="none" stroke="url(#serpent-g)" stroke-width="2" opacity="0.6" filter="url(#serpent-glow)">
    <path d="M600,555 Q560,510 600,495 Q640,480 600,465 Q560,450 600,420"/>
    <path d="M600,420 Q560,405 600,390 Q640,375 600,345"/>
    <path d="M600,345 Q560,330 600,315 Q640,300 600,285 Q560,270 600,270"/>
  </g>
  <!-- Serpent head at crown -->
  <g transform="translate(600,260)" filter="url(#serpent-glow)">
    <ellipse rx="8" ry="12" fill="#FFD700" opacity="0.7"/>
    <circle cx="-4" cy="-4" r="1.5" fill="#0A0A0F"/>
    <circle cx="4" cy="-4" r="1.5" fill="#0A0A0F"/>
  </g>
  <text x="600" y="50" text-anchor="middle" font-family="serif" font-size="11" fill="#C9A84C" opacity="0.6" letter-spacing="4">✦ KUNDALINI SHAKTI ✦</text>
</svg>
