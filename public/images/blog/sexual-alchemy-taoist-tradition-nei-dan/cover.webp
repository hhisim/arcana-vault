<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <radialGradient id="bg9" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1a0a10"/>
      <stop offset="100%" stop-color="#0A0A0F"/>
    </radialGradient>
    <linearGradient id="elixir9" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#e74c3c"/>
      <stop offset="50%" stop-color="#C9A84C"/>
      <stop offset="100%" stop-color="#4ECDC4"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg9)"/>
  <!-- Three treasures: Jing (red), Qi (gold), Shen (teal) -->
  <g transform="translate(600,280)" opacity="0.3">
    <circle r="200" fill="none" stroke="#C9A84C" stroke-width="0.5"/>
    <circle r="150" fill="none" stroke="#C9A84C" stroke-width="0.5"/>
    <!-- Taiji (three balances) -->
    <circle r="100" fill="none" stroke="#C9A84C" stroke-width="0.5"/>
    <circle cx="0" cy="-50" r="30" fill="#e74c3c" opacity="0.2"/>
    <circle cx="0" cy="50" r="30" fill="#4ECDC4" opacity="0.2"/>
    <circle cx="0" cy="0" r="15" fill="#C9A84C" opacity="0.3"/>
  </g>
  <!-- Inner elixir flask shape -->
  <g transform="translate(600,320)" opacity="0.4">
    <path d="M-40,0 L-30,-100 L30,-100 L40,0 Q40,40 0,60 Q-40,40 -40,0" fill="none" stroke="url(#elixir9)" stroke-width="1.5"/>
    <ellipse cx="0" cy="-20" rx="20" ry="8" fill="#e74c3c" opacity="0.3"/>
    <ellipse cx="0" cy="10" rx="25" ry="10" fill="#C9A84C" opacity="0.3"/>
  </g>
  <!-- Label -->
  <text x="600" y="50" text-anchor="middle" font-family="serif" font-size="11" fill="#C9A84C" opacity="0.7" letter-spacing="4">✦ NEI DAN · JING QI SHEN ✦</text>
  <text x="600" y="585" text-anchor="middle" font-family="serif" font-size="9" fill="#9B93AB" opacity="0.4" letter-spacing="2">Three Treasures · Internal Elixir · Sexual Alchemy</text>
</svg>
